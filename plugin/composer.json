{
    "name": "wp-agent/wp-agent",
    "description": "The Open Source AI Agent for WordPress — MCP Server for AI IDE integration",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "version": "0.1.0",
    "keywords": [
        "wordpress",
        "mcp",
        "ai",
        "agent",
        "model-context-protocol",
        "cursor",
        "claude",
        "chatgpt"
    ],
    "homepage": "https://github.com/wp-agent/wp-agent",
    "support": {
        "issues": "https://github.com/wp-agent/wp-agent/issues",
        "source": "https://github.com/wp-agent/wp-agent"
    },
    "authors": [
        {
            "name": "WP Agent Contributors",
            "homepage": "https://github.com/wp-agent"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "firebase/php-jwt": "^6.10",
        "psr/log": "^3.0",
        "psr/container": "^2.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "WpAgent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WpAgent\\Tests\\": "Tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.2.0"
        },
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:coverage": "phpunit --coverage-clover=coverage.xml",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "cs:fix": "phpcbf",
        "qa": [
            "@cs",
            "@stan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the full PHPUnit test suite",
        "stan": "Run PHPStan static analysis at maximum level",
        "cs": "Check code style against WordPress Coding Standards",
        "cs:fix": "Auto-fix code style violations",
        "qa": "Run all quality assurance checks (cs + stan + test)"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
